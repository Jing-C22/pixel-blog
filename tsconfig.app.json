.app-root {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: var(--color-bg-deep);
}

/* ---------- island background ---------- */
.island-layer {
  position: absolute;
  inset: 0;
}

.island-svg {
  width: 100%;
  height: 100%;
  display: block;
}

/* ---------- zone markers ---------- */
.zone-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.zone-marker {
  position: absolute;
  transform: translate(-50%, -50%);
  pointer-events: auto;
}

.zone-marker-button {
  background: none;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  transition: transform 0.15s ease;
  filter: drop-shadow(2px 3px 0 rgba(0, 0, 0, 0.5));
}

.zone-marker-button:hover,
.zone-marker-button:focus-visible {
  transform: translateY(-6px) scale(1.08);
}

.zone-marker-button:active {
  transform: translateY(-2px) scale(0.97);
}

.zone-sprite-svg {
  width: 56px;
  height: 56px;
  image-rendering: pixelated;
  animation: bob 3.4s ease-in-out infinite;
}

.zone-marker:nth-of-type(2) .zone-sprite-svg {
  animation-delay: -1.1s;
}
.zone-marker:nth-of-type(3) .zone-sprite-svg {
  animation-delay: -2.2s;
}
.zone-marker:nth-of-type(4) .zone-sprite-svg {
  animation-delay: -0.5s;
}

@keyframes bob {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4px);
  }
}

.zone-label {
  font-size: 8px;
  color: var(--color-text);
  background: var(--color-bg-deep);
  padding: 3px 5px;
  border: 2px solid var(--color-accent-teal);
  white-space: nowrap;
}

.zone-popover {
  position: absolute;
  top: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 220px;
  max-width: 260px;
  padding: 10px;
  z-index: 5;
  animation: popIn 0.15s ease-out;
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(-6px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
}

.zone-popover-header {
  font-size: 9px;
  color: var(--color-accent-yellow);
  margin-bottom: 8px;
}

.zone-post-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.zone-post-empty {
  font-size: 16px;
  color: var(--color-text-dim);
  font-style: italic;
}

.zone-post-item {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--color-panel-light);
  border: 2px solid transparent;
  color: var(--color-text);
  padding: 6px 8px;
  font-family: var(--font-mono);
  font-size: 17px;
  text-align: left;
  transition: border-color 0.1s, background 0.1s;
}

.zone-post-item:hover,
.zone-post-item:focus-visible {
  border-color: var(--color-accent-pink);
  background: #322a52;
}

.zone-post-icon {
  font-size: 16px;
}

/* ---------- windows ---------- */
.window-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.post-window {
  position: absolute;
  width: 460px;
  max-width: calc(100vw - 32px);
  max-height: calc(100vh - 96px);
  display: flex;
  flex-direction: column;
  pointer-events: auto;
  transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.18s ease-out;
}

.post-window.is-opening {
  opacity: 0;
  transform: scale(0.15);
}

.post-window.is-open {
  opacity: 1;
  transform: scale(1);
}

.post-window-titlebar {
  height: var(--titlebar-h);
  background: linear-gradient(
    180deg,
    var(--color-accent-pink) 0%,
    #d9447f 100%
  );
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8px;
  touch-action: none;
  user-select: none;
  cursor: url("/sprites/cursor-pointer.svg") 6 2, grab;
  border-bottom: 3px solid var(--color-bg-deep);
}

.post-window-title {
  font-size: 10px;
  color: #1a0a14;
  display: flex;
  align-items: center;
  gap: 6px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-window-icon {
  font-size: 13px;
}

.post-window-controls {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.win-btn {
  width: 22px;
  height: 22px;
  border: 2px solid var(--color-bg-deep);
  background: var(--color-panel-light);
  color: var(--color-text);
  font-family: var(--font-pixel);
  font-size: 10px;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.win-btn:hover {
  background: var(--color-accent-yellow);
  color: var(--color-bg-deep);
}

.win-btn-close:hover {
  background: #ff4d4d;
  color: white;
}

.post-window-body {
  flex: 1;
  overflow-y: auto;
  padding: 18px 20px 22px;
  background: var(--color-panel);
}

.post-content h1 {
  font-family: var(--font-pixel);
  font-size: 16px;
  line-height: 1.5;
  color: var(--color-accent-yellow);
  margin: 0 0 6px;
}

.post-date {
  display: block;
  font-size: 15px;
  color: var(--color-text-dim);
  margin-bottom: 16px;
}

.post-content p {
  font-size: 19px;
  line-height: 1.6;
  margin: 0 0 14px;
  color: var(--color-text);
}

.post-content ul,
.post-content ol {
  font-size: 19px;
  line-height: 1.6;
  margin: 0 0 14px;
  padding-left: 24px;
}

.post-content a {
  color: var(--color-accent-teal);
}

.post-content strong {
  color: var(--color-accent-pink);
}

.post-content code {
  background: var(--color-bg-deep);
  padding: 1px 5px;
  font-size: 0.9em;
  border: 1px solid var(--color-accent-teal);
}

/* ---------- taskbar ---------- */
.taskbar {
  position: absolute;
  left: 12px;
  right: 12px;
  bottom: 12px;
  height: 42px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 10px;
  z-index: 999;
}

.taskbar-brand {
  font-size: 10px;
  color: var(--color-accent-yellow);
  flex-shrink: 0;
}

.taskbar-windows {
  flex: 1;
  display: flex;
  gap: 8px;
  overflow-x: auto;
}

.taskbar-item {
  flex-shrink: 0;
  background: var(--color-panel-light);
  border: 2px solid var(--color-accent-teal);
  color: var(--color-text);
  font-family: var(--font-mono);
  font-size: 16px;
  padding: 4px 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.taskbar-item:hover {
  background: var(--color-accent-teal);
  color: var(--color-bg-deep);
}

.taskbar-mute {
  flex-shrink: 0;
  background: var(--color-panel-light);
  border: 2px solid var(--color-border);
  width: 30px;
  height: 30px;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---------- intro hint ---------- */
.intro-hint {
  position: absolute;
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 9px;
  color: var(--color-text-dim);
  background: rgba(13, 10, 20, 0.6);
  padding: 8px 12px;
  border: 2px solid var(--color-panel-light);
  pointer-events: none;
  animation: fadeHint 6s ease forwards;
}

@keyframes fadeHint {
  0%,
  70% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

/* ---------- CRT overlay ---------- */
.crt-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 2000;
}

.crt-scanlines {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.12) 0px,
    rgba(0, 0, 0, 0.12) 1px,
    transparent 1px,
    transparent 3px
  );
  mix-blend-mode: multiply;
  opacity: 0.5;
}

.crt-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse at center,
    transparent 55%,
    rgba(0, 0, 0, 0.45) 100%
  );
}

/* ---------- noscript fallback ---------- */
.noscript-fallback {
  position: fixed;
  inset: 0;
  background: var(--color-bg);
  color: var(--color-text);
  padding: 40px;
  overflow-y: auto;
}

/* ---------- responsive ---------- */
@media (max-width: 640px) {
  .post-window {
    width: calc(100vw - 24px);
    left: 12px !important;
  }
  .zone-label {
    font-size: 7px;
  }
  .zone-sprite-svg {
    width: 42px;
    height: 42px;
  }
  .taskbar-brand {
    display: none;
  }
}
